{
  "name": "sharpbasic-syntax",
  "displayName": "SharpBASIC",
  "description": "Syntax highlighting for SharpBASIC (.sbx) files",
  "version": "0.2.0",
  "publisher": "kwakker35",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kwakker35/SharpBasic"
  },
  "contributes": {
    "languages": [
      {
        "id": "sharpbasic",
        "aliases": [
          "SharpBASIC",
          "sharpbasic"
        ],
        "extensions": [
          ".sbx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sharpbasic",
        "scopeName": "source.sharpbasic",
        "path": "./syntaxes/sharpbasic.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "constant.numeric.sharpbasic",
            "settings": { "foreground": "#4EC9B0" }
          }
        ]
      }
    }
  }
}
